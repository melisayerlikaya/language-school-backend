generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  TEACHER
}

model User {
  id       Int    @id @default(autoincrement())
  fullName String
  email    String @unique
  password String
  role     Role

  lessons Lesson[]
}


model Lesson {
  id Int @id @default(autoincrement())

  title String
  day   String
  start String
  end   String
  color String

  teacherId Int
  teacher User @relation(fields: [teacherId], references: [id], onDelete: Cascade)
}